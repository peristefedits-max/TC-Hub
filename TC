-- // Function: create an image button
local function CreateImageButton(name, imageId, scriptUrl, layoutOrder)
    local BtnFrame = Instance.new("Frame")
    BtnFrame.Name = name
    BtnFrame.Size = UDim2.new(1, -10, 0, 90)  -- taller for image
    BtnFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    BtnFrame.BackgroundTransparency = 0.4
    BtnFrame.BorderSizePixel = 0
    BtnFrame.LayoutOrder = layoutOrder
    BtnFrame.ClipsDescendants = true
    BtnFrame.Parent = ScriptList

    local BtnCorner = Instance.new("UICorner", BtnFrame)
    BtnCorner.CornerRadius = UDim.new(0, 10)

    -- Background image for the button
    local BtnImage = Instance.new("ImageLabel")
    BtnImage.Size = UDim2.new(1, 0, 1, 0)
    BtnImage.BackgroundTransparency = 1
    BtnImage.ScaleType = Enum.ScaleType.Crop
    BtnImage.Image = imageId  -- Use Roblox asset ID or URL
    BtnImage.Parent = BtnFrame

    -- Dark overlay so text pops
    local ImageOverlay = Instance.new("Frame")
    ImageOverlay.Size = UDim2.new(1, 0, 1, 0)
    ImageOverlay.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    ImageOverlay.BackgroundTransparency = 0.5
    ImageOverlay.BorderSizePixel = 0
    ImageOverlay.Parent = BtnFrame

    -- Text label
    local BtnText = Instance.new("TextLabel")
    BtnText.Size = UDim2.new(1, 0, 1, 0)
    BtnText.BackgroundTransparency = 1
    BtnText.Text = name
    BtnText.TextColor3 = Color3.fromRGB(255, 255, 255)
    BtnText.Font = Enum.Font.GothamBold
    BtnText.TextSize = 18
    BtnText.TextStrokeTransparency = 0.6
    BtnText.Parent = BtnFrame

    -- Make it clickable
    local BtnButton = Instance.new("TextButton")
    BtnButton.Size = UDim2.new(1, 0, 1, 0)
    BtnButton.BackgroundTransparency = 1
    BtnButton.Text = ""
    BtnButton.Parent = BtnFrame

    BtnButton.MouseButton1Click:Connect(function()
        if scriptUrl and scriptUrl ~= "" then
            pcall(function()
                loadstring(game:HttpGet(scriptUrl))()
            end)
        end
    end)

    -- Hover effect (brighten overlay)
    BtnButton.MouseEnter:Connect(function()
        ImageOverlay.BackgroundTransparency = 0.2
    end)
    BtnButton.MouseLeave:Connect(function()
        ImageOverlay.BackgroundTransparency = 0.5
    end)

    return BtnFrame
end

