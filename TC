-- // ---- DYNAMIC GITHUB LOADER (optional) ----
local MANIFEST_URL = "https://raw.githubusercontent.com/YOUR_USERNAME/YOUR_REPO/main/scripts.lua"

coroutine.wrap(function()
    local success, result = pcall(function()
        return game:HttpGet(MANIFEST_URL)
    end)
    if success and result then
        local func, err = loadstring("return " .. result)
        if func then
            local scripts = func()
            if type(scripts) == "table" then
                local i = 6
                for _, scriptData in ipairs(scripts) do
                    if scriptData.Name and scriptData.URL then
                        CreateImageButton(scriptData.Name, scriptData.Image or "", scriptData.URL, i)
                        i = i + 1
                    end
                end
            end
        end
    end
end)()
